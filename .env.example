# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/assisto
POSTGRESQL_URL=postgresql://user:password@localhost:5432/assisto_db
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production
REFRESH_TOKEN_EXPIRATION=7d

# AI Services Configuration
AI_SERVICE_URL=http://localhost:5001
TRANSLATION_API_KEY=your_translation_api_key
HAZARD_DETECTION_API_KEY=your_hazard_detection_key

# External APIs
USGS_API_KEY=your_usgs_api_key
NOAA_API_KEY=your_noaa_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Security
ENCRYPTION_KEY=your_32_character_encryption_key_here
SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password
SENDER_EMAIL=noreply@assisto.io

# Twilio Configuration (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Socket.io Configuration
SOCKET_IO_CORS_ORIGIN=*
SOCKET_IO_PING_INTERVAL=25000
SOCKET_IO_PING_TIMEOUT=60000

# Feature Flags
ENABLE_HAZARD_DETECTION=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_LOCATION_SHARING=true
ENABLE_EMERGENCY_OPS=true

# Responder Network
RESPONDER_VERIFICATION_REQUIRED=true
RESPONDER_BACKGROUND_CHECK=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Alert Configuration
ALERT_RETENTION_DAYS=30
ALERT_NOTIFICATION_RETRY=3

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# Environment
IS_PRODUCTION=false
DEBUG=true
